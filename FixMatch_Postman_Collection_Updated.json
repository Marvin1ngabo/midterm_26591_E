{
  "info": {
    "name": "FixMatch API - Unified Hierarchical Location System",
    "description": "Complete API collection for FixMatch with unified hierarchical location system using single Location table with parent-child relationships (Adjacency List Model). Supports Province → District → Sector → Cell → Village hierarchy with village ID-based user registration for better efficiency and accuracy.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
